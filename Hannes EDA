COST_PER_KM      = 1.50   # € per km for home delivery
FIXED_PER_SP     = 50_000 # € per service point per year
STORAGE_PER_PKG  = 0.10   # € per package per day in storage
AVG_DWELL_DAYS   = 2      # assumed average days a package waits at SP

# =============================================================================
# 0. LOAD DATA
# =============================================================================
xl    = pd.ExcelFile(DATA_PATH)
sp    = pd.read_excel(xl, "Service Point Locations")
