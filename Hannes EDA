      f"but adds €{AVG_DWELL_DAYS * STORAGE_PER_PKG:.2f} storage)")

# =============================================================================
# 4. CAPACITY PRESSURE ANALYSIS
# =============================================================================
# Daily statistics per SP (pickups drive storage load)
daily_sp = da.groupby(["Location ID", "Date"]).agg(
    daily_pickups   =("Pickups",    "sum"),
    daily_deliveries=("Deliveries", "sum"),
).reset_index()
daily_sp["daily_total"] = daily_sp["daily_pickups"] + daily_sp["daily_deliveries"]

cap = daily_sp.groupby("Location ID").agg(
    avg_pickups =("daily_pickups",  "mean"),
    p90_pickups =("daily_pickups",  lambda x: x.quantile(0.90)),
    p95_pickups =("daily_pickups",  lambda x: x.quantile(0.95)),
    max_pickups =("daily_pickups",  "max"),
    avg_total   =("daily_total",    "mean"),
    max_total   =("daily_total",    "max"),
    cv_pickups  =("daily_pickups",  lambda x: x.std() / x.mean()),  # variability
).reset_index()

cap["peak_ratio"]  = cap["max_pickups"]  / cap["avg_pickups"]  # max / avg
cap["p95_ratio"]   = cap["p95_pickups"]  / cap["avg_pickups"]  # 95th pct / avg

df = df.merge(cap, on="Location ID")

# =============================================================================
# 5. BOUNCE-RISK SCORING
# =============================================================================
# Bounce risk = package cannot be stored because SP is at/over capacity.
# We don't have explicit capacity limits, so we proxy with:
#   - High avg daily pickups (absolute load)
#   - High peak-to-average ratio (variability / spikiness)
#   - High coefficient of variation (unpredictable load)
# Score each on a 0–1 scale, then combine.

def minmax(series):
    return (series - series.min()) / (series.max() - series.min() + 1e-9)

df["score_volume"]   = minmax(df["avg_pickups"])   # high volume = bad
df["score_spikes"]   = minmax(df["peak_ratio"])    # high spikes = bad
df["score_variability"] = minmax(df["cv_pickups"]) # high CV = bad

# Weighted composite (volume matters most)
df["bounce_risk_score"] = (
    0.50 * df["score_volume"] +
    0.30 * df["score_spikes"] +
    0.20 * df["score_variability"]
)
df["bounce_risk_label"] = pd.cut(
    df["bounce_risk_score"],
    bins=[0, 0.33, 0.66, 1.01],
    labels=["Low", "Medium", "High"]
)

