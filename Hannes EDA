print(f"Loaded: {len(sp)} service points, {len(da):,} daily records, "
      f"{len(nodes):,} nodes, {len(edges):,} edges")

# =============================================================================
# 1. COMPUTE ROAD-NETWORK DISTANCES  (SP → catchment squares)
# =============================================================================
# Build graph
G = nx.Graph()
for _, r in nodes.iterrows():
    G.add_node(int(r["NODE ID"]), x=r["X"], y=r["Y"])
for _, r in edges.iterrows():
    G.add_edge(int(r["V1"]), int(r["V2"]), weight=float(r["DIST"]))

# Keep largest connected component
G = G.subgraph(max(nx.connected_components(G), key=len)).copy()

node_coords = np.array([[G.nodes[n]["x"], G.nodes[n]["y"]] for n in G.nodes()])
node_ids    = np.array(list(G.nodes()))

def nearest_node(x, y):
    diffs = node_coords - np.array([x, y])
    return node_ids[np.argmin((diffs**2).sum(axis=1))]

sp["node"] = sp.apply(lambda r: nearest_node(r["X"], r["Y"]), axis=1)

cbs = pd.read_excel(xl, "CBS Squares")
cbs_pop = cbs[cbs["Population"].notna()].copy()
cbs_pop["node"] = cbs_pop.apply(lambda r: nearest_node(r["X"], r["Y"]), axis=1)

print("Running Dijkstra from each service point…")
sp_dist_maps = {}
for _, row in sp.iterrows():
    sp_dist_maps[row["Location ID"]] = nx.single_source_dijkstra_path_length(
        G, row["node"], weight="weight"
    )

sp_ids = sp["Location ID"].tolist()
dist_matrix = np.full((len(cbs_pop), len(sp_ids)), np.inf)
for j, sid in enumerate(sp_ids):
    dmap = sp_dist_maps[sid]
    for i, n in enumerate(cbs_pop["node"].values):
        dist_matrix[i, j] = dmap.get(int(n), np.inf)

nearest_idx              = np.argmin(dist_matrix, axis=1)
cbs_pop["nearest_sp"]    = [sp_ids[k] for k in nearest_idx]
cbs_pop["dist_to_sp_m"]  = dist_matrix[np.arange(len(cbs_pop)), nearest_idx]
cbs_pop["dist_to_sp_km"] = cbs_pop["dist_to_sp_m"] / 1000.0

# Weighted average delivery distance per SP (pop-weighted)
def avg_catchment_dist(sp_id):
    sub = cbs_pop[cbs_pop["nearest_sp"] == sp_id]
    if sub.empty or sub["Population"].sum() == 0:
        return np.nan
    return np.average(sub["dist_to_sp_km"], weights=sub["Population"])

sp["avg_dist_km"] = sp["Location ID"].apply(avg_catchment_dist)

# =============================================================================
# 2. ANNUAL ACTIVITY PER SERVICE POINT
# =============================================================================
annual = da.groupby("Location ID").agg(
    total_deliveries=("Deliveries", "sum"),
    total_pickups   =("Pickups",    "sum"),
    active_days     =("Date",       "count"),
).reset_index()

annual["total_parcels"]  = annual["total_deliveries"] + annual["total_pickups"]
annual["pickup_rate"]    = annual["total_pickups"] / annual["total_parcels"]
annual["avg_daily_del"]  = annual["total_deliveries"] / annual["active_days"]
annual["avg_daily_pick"] = annual["total_pickups"]    / annual["active_days"]
annual["avg_daily_tot"]  = annual["total_parcels"]    / annual["active_days"]

df = sp.merge(annual, on="Location ID")

# =============================================================================
# 3. COST ESTIMATION
# =============================================================================
# 3a. Delivery cost: volume-weighted by road distance
df["delivery_cost"] = df["total_deliveries"] * df["avg_dist_km"] * COST_PER_KM

# 3b. Fixed cost: same for every SP
df["fixed_cost"] = float(FIXED_PER_SP)

# 3c. Storage cost: pickups × dwell × daily rate
df["storage_cost"] = df["total_pickups"] * AVG_DWELL_DAYS * STORAGE_PER_PKG

# 3d. Total
df["total_cost"] = df["delivery_cost"] + df["fixed_cost"] + df["storage_cost"]
df["cost_per_parcel"] = df["total_cost"] / df["total_parcels"]

# Network-level summary
total_delivery = df["delivery_cost"].sum()
total_fixed    = df["fixed_cost"].sum()
total_storage  = df["storage_cost"].sum()
total_cost     = df["total_cost"].sum()

