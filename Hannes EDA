print(f"  Storage (€{STORAGE_PER_PKG}/pkg/day × {AVG_DWELL_DAYS}d): €{total_storage:>10,.0f}  ({total_storage/total_cost:.1%})")
print(f"  TOTAL:                        €{total_cost:>10,.0f}")
print("="*55)

# Counterfactual: what if all parcels were delivered at home?
df["cost_all_delivery"]   = df["total_parcels"] * df["avg_dist_km"] * COST_PER_KM + FIXED_PER_SP
df["pickup_channel_saving"] = df["cost_all_delivery"] - df["total_cost"]
net_pickup_saving = df["pickup_channel_saving"].sum()
